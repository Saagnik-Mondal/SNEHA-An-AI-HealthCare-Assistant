# SNEHA login configuration (OPTIONAL).
# Copy this file to ".streamlit/secrets.toml" and fill in your own values.
# Without it, SNEHA runs in guest mode (chats still save locally).
# Do NOT commit the real secrets.toml — it is gitignored.

[auth]
# Where the OAuth provider sends users back after sign-in.
# Must EXACTLY match the redirect URI you register, and match the port you run on.
redirect_uri = "http://localhost:8501/oauth2callback"
# Any long random string. Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
cookie_secret = "REPLACE_WITH_A_LONG_RANDOM_STRING"

# ---- Google ----
# Create credentials at https://console.cloud.google.com/apis/credentials
# (OAuth client ID -> Web application). Add the redirect_uri above to "Authorized redirect URIs".
[auth.google]
client_id = "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_GOOGLE_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# ---- Microsoft ----
# Register an app at https://portal.azure.com -> Microsoft Entra ID -> App registrations.
# Add the redirect_uri above as a Web redirect URI; create a client secret.
# For personal + work accounts use the "common" tenant in the metadata URL below.
[auth.microsoft]
client_id = "YOUR_AZURE_APP_CLIENT_ID"
client_secret = "YOUR_AZURE_CLIENT_SECRET"
server_metadata_url = "https://login.microsoftonline.com/common/v2.0/.well-known/openid-configuration"
